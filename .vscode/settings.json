{
  // ============================================================================
  // Cursor IDE / VSCode м„Өм •
  // ============================================================================
  // мқҙ нҢҢмқјмқҖ .editorconfigмҷҖ н•Ёк»ҳ мһ‘лҸҷн•ҳм—¬ мқјкҙҖлҗң мҪ”л“ң мҠӨнғҖмқјмқ„ мң м§Җн•©лӢҲлӢӨ.

  // м—җл””н„° кё°ліё м„Өм •
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.rulers": [156],
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.encoding": "utf8",
  "files.eol": "\n",

  // Java м–ём–ҙ м„ңлІ„ м„Өм •
  "[java]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.java"
  },

  // Java нҸ¬л§·нҢ… м„Өм • (Language Support for Java)
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.format.settings.profile": "GoogleStyle",
  "java.format.enabled": true,
  "java.format.comments.enabled": false,

  // Import кҙҖлҰ¬
  "java.completion.importOrder": ["com.bifos", "java", "javax", "org", ""],

  // кё°нғҖ Java м„Өм •
  "java.saveActions.organizeImports": true,

  // Checkstyle м„Өм • (Checkstyle for Java нҷ•мһҘ н•„мҡ”)
  "java.checkstyle.configuration": "${workspaceFolder}/config/checkstyle/google_checks.xml",
  "java.checkstyle.version": "10.12.4",

  // м¶”мІң нҷ•мһҘ н”„лЎңк·ёлһЁ
  "recommendations": ["redhat.java", "vscjava.vscode-java-pack", "vscjava.vscode-java-debug", "vscjava.vscode-maven", "shengchen.vscode-checkstyle"],
  "java.compile.nullAnalysis.mode": "automatic"
}
